import math
import random
from dataclasses import dataclass, field
from typing import Dict, List, Tuple, Any, Optional

import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import simpy

try:
    from scipy import stats as sps
    SCIPY = True
except Exception:
    SCIPY = False


BUCKET = 30.0                                    # janela de amostragem intradiária (min)
POSTOS_LIMITADOS = ("Personalização", "Etiquetagem", "Embalagem")
FLUXO = ["Separação", "Personalização", "Etiquetagem", "Embalagem", "Expedição"]


# ============================== ENTIDADES ==============================

@dataclass
class Pedido:
    id_pedido: int
    tempo_chegada: float
    prioridade: int
    itens: int = 1
    tempo_total_fila: float = 0.0
    tempo_fim: float = 0.0
    retrabalhos_sofridos: int = 0

    def __lt__(self, other: "Pedido") -> bool:
        return self.prioridade < other.prioridade


@dataclass
class Operador:
    id_operador: str
    posto_original: str
    tempo_medio_base: float
    eficiencia_base: float
    tipo_contrato: str                           # "CLT" | "Estágio" | "MeioPeriodo"
    polivalencia: List[str] = field(default_factory=list)
    turno: Optional[str] = None
    posto_atual: str = field(init=False)
    tempo_medio_cenario: float = field(init=False)
    tempo_trabalhado: float = 0.0
    disponivel: bool = field(default=True, init=False)

    def __post_init__(self) -> None:
        self.posto_atual = self.posto_original
        self.tempo_medio_cenario = self.tempo_medio_base


# ============================== CONFIGURAÇÃO ==============================

class DadosConfig:
    MINUTOS_POR_DIA_UTIL = 480.0
    MINUTOS_SABADO = 240.0
    MINUTOS_ESTAGIO_DIA = 330.0
    JORNADA_SEMANAL_CLT = 2640.0
    JORNADA_SEMANAL_ESTAGIO = 1650.0
    JORNADA_SEMANAL_MEIO_PERIODO = 750.0
    LIMITES_DIAS = [0.0, 480.0, 960.0, 1440.0, 1920.0, 2400.0, 2640.0]

    TEMPO_SEPARACAO = 2.0
    TEMPO_EXPEDICAO = 2.0

    # Volume diário sorteado em [70, 120]. Com True, o sábado recebe demanda
    # proporcional à sua jornada (metade da faixa); com False, a mesma faixa dos
    # dias úteis. Confirmar no ERP antes de fixar os resultados finais.
    DEMANDA_SABADO_PROPORCIONAL = False

    @staticmethod
    def obter_operadores_base() -> List[Operador]:
        return [
            Operador("OP-PR-01", "Personalização", 2.0, 0.833, "CLT"),
            Operador("OP-PR-02", "Personalização", 2.0, 0.667, "CLT", ["Embalagem"]),
            Operador("OP-ET-01", "Etiquetagem", 3.0, 0.850, "CLT"),
            Operador("OP-ET-02", "Etiquetagem", 3.5, 0.778, "Estágio", ["Polivalente"]),
            Operador("OP-ET-03", "Etiquetagem", 2.5, 0.875, "Estágio"),
            Operador("OP-ET-04", "Etiquetagem", 2.5, 0.625, "Estágio"),
            Operador("OP-ET-05", "Etiquetagem", 3.0, 0.800, "Estágio"),
            Operador("OP-EM-01", "Embalagem", 1.74, 0.686, "Estágio"),
            Operador("OP-EM-02", "Embalagem", 1.91, 0.677, "CLT"),
            Operador("OP-EM-03", "Embalagem", 2.00, 0.700, "Estágio", ["Etiquetagem"]),
        ]

    @staticmethod
    def configurar_cenario(id_cenario: int, operadores: List[Operador],
                           params: Dict[str, Any]) -> Tuple[Dict[str, Any], List[Operador]]:
        regras: Dict[str, Any] = {
            "fator_deslocamento": 1.0,
            "taxa_retrabalho": params.get("taxa_retrabalho", 0.10),
            "tempo_deslocamento_base": 0.5,
            "balanceamento_enxuto": False,
            "expansao_capacidade": False,
            "limite_fila_gargalo": params.get("limite_fila_gargalo", 3),
            "limite_fila_normalizacao": 1,
            "cv_tempos": params.get("cv_tempos", 0.15),
            "turnos_escalonados": False,
            "contratacao_parcial": False,
            "jornada_homogenea": False,
            "polivalencia_ampliada": params.get("polivalencia_ampliada", False),
            "cap_separacao": params.get("cap_separacao", None),
        }

        # Numeração idêntica à do texto: 0 controle, 1 atual, 2..8 melhorias
        # incrementais, 9 turnos escalonados, 10 contratação parcial.
        mapa = {
            0:  dict(jornada_homogenea=True),
            1:  dict(),
            2:  dict(estudo_tempos=True),
            3:  dict(novo_layout=True),
            4:  dict(balanceamento_enxuto=True),
            5:  dict(expansao_capacidade=True),
            6:  dict(estudo_tempos=True, novo_layout=True),
            7:  dict(estudo_tempos=True, novo_layout=True, balanceamento_enxuto=True),
            8:  dict(estudo_tempos=True, novo_layout=True, expansao_capacidade=True),
            9:  dict(estudo_tempos=True, novo_layout=True, turnos_escalonados=True),
            10: dict(estudo_tempos=True, novo_layout=True, contratacao_parcial=True),
        }
        flags = mapa.get(id_cenario, dict())
        estudo_tempos = flags.get("estudo_tempos", False)
        novo_layout = flags.get("novo_layout", False)
        for k in ("balanceamento_enxuto", "expansao_capacidade",
                  "turnos_escalonados", "contratacao_parcial", "jornada_homogenea"):
            regras[k] = flags.get(k, False)

        if estudo_tempos:
            for op in operadores:
                op.eficiencia_base = max(op.eficiencia_base, 0.85)
        if novo_layout:
            regras["fator_deslocamento"] = 0.50
        if regras["expansao_capacidade"]:
            operadores.append(Operador("OP-EXP-01", "Personalização", 2.0, 0.833, "CLT"))

        # Cenário de controle: capacidade contínua ao longo da semana, para
        # isolar o efeito da descontinuidade de jornada.
        if regras["jornada_homogenea"]:
            for op in operadores:
                op.tipo_contrato = "CLT"
                op.turno = None

        if regras["turnos_escalonados"]:
            estagiarios = [op for op in operadores if op.tipo_contrato == "Estágio"]
            for i, op in enumerate(estagiarios):
                op.turno = "manha" if i % 2 == 0 else "tarde"

        if regras["contratacao_parcial"]:
            operadores.append(Operador("OP-MP-01", "Etiquetagem", 3.0, 0.85,
                                       "MeioPeriodo", turno="meio_periodo_tarde"))

        for op in operadores:
            op.tempo_medio_cenario = op.tempo_medio_base / op.eficiencia_base
        return regras, operadores


# ============================== MODELO ==============================

class EmpresaAlpha:
    def __init__(self, env: simpy.Environment, id_cenario: int,
                 params: Dict[str, Any], rngs: Dict[str, Any]) -> None:
        self.env = env
        self.id_cenario = id_cenario
        self.rng_serv = rngs["servico"]
        self.rng_ret = rngs["retrabalho"]

        base = DadosConfig.obter_operadores_base()
        self.regras, self.operadores = DadosConfig.configurar_cenario(id_cenario, base, params)
        self.alocacao_postos = self._calcular_capacidade_postos()
        self.capacidade_minima = dict(self.alocacao_postos)

        cap_sep = self.regras["cap_separacao"]
        self.postos: Dict[str, simpy.PriorityResource] = {
            "Separação": simpy.PriorityResource(env, capacity=cap_sep if cap_sep else 999),
            "Personalização": simpy.PriorityResource(env, capacity=self.alocacao_postos["Personalização"]),
            "Etiquetagem": simpy.PriorityResource(env, capacity=self.alocacao_postos["Etiquetagem"]),
            "Embalagem": simpy.PriorityResource(env, capacity=self.alocacao_postos["Embalagem"]),
            "Expedição": simpy.PriorityResource(env, capacity=999),
        }

        self.pedidos_finalizados: List[Pedido] = []
        self.pedidos_ativos: Dict[int, Pedido] = {}
        self.contador_retrabalhos = 0
        self.total_chegados = 0
        self.alertas: List[str] = []

        self.wip_atual = 0
        self._wip_area = 0.0
        self._wip_last_t = 0.0

        self.n_buckets = int(math.ceil(DadosConfig.LIMITES_DIAS[-1] / BUCKET))
        self.ocupacao = {p: np.zeros(self.n_buckets) for p in POSTOS_LIMITADOS}
        self.cap_bucket = {p: np.zeros(self.n_buckets) for p in POSTOS_LIMITADOS}
        self.bloqueados = {p: 0 for p in POSTOS_LIMITADOS}

        for op in self.operadores:
            if op.tipo_contrato == "Estágio":
                env.process(self._indisponibilidade_estagiario(op))
            elif op.tipo_contrato == "MeioPeriodo":
                env.process(self._indisponibilidade_meio_periodo(op))

        env.process(self._monitor_capacidade())

        self._apoio_ativo = False
        self._operador_emprestado: Optional[Operador] = None
        if self.regras["balanceamento_enxuto"]:
            env.process(self._balanceamento_linha())

    # ---------------- WIP ----------------
    def _wip_update(self):
        agora = self.env.now
        self._wip_area += self.wip_atual * (agora - self._wip_last_t)
        self._wip_last_t = agora

    def _wip_incr(self):
        self._wip_update(); self.wip_atual += 1

    def _wip_decr(self):
        self._wip_update(); self.wip_atual -= 1

    # ---------------- instrumentação intradiária ----------------
    def _registra_ocupacao(self, posto: str, t_ini: float, t_fim: float) -> None:
        if posto not in self.ocupacao:
            return
        b = int(t_ini // BUCKET)
        while t_ini < t_fim and b < self.n_buckets:
            corte = min(t_fim, (b + 1) * BUCKET)
            self.ocupacao[posto][b] += corte - t_ini
            t_ini = corte
            b += 1

    def _monitor_capacidade(self):
        for b in range(self.n_buckets):
            for p in POSTOS_LIMITADOS:
                self.cap_bucket[p][b] = max(0.0, self.postos[p].capacity - self.bloqueados[p])
            yield self.env.timeout(BUCKET)

    def _calcular_capacidade_postos(self) -> Dict[str, int]:
        cap = {"Separação": 999, "Personalização": 0, "Etiquetagem": 0,
               "Embalagem": 0, "Expedição": 999}
        for op in self.operadores:
            if op.posto_atual in cap:
                cap[op.posto_atual] += 1
        for p in cap:
            if cap[p] == 0:
                cap[p] = 1
        return cap

    # ---------------- disponibilidade ----------------
    def _bloquear(self, operador: Operador, duracao: float):
        posto = operador.posto_atual
        with self.postos[posto].request(priority=-1) as req:
            yield req
            operador.disponivel = False
            if posto in self.bloqueados:
                self.bloqueados[posto] += 1
            try:
                yield self.env.timeout(duracao)
            finally:
                operador.disponivel = True
                if posto in self.bloqueados:
                    self.bloqueados[posto] -= 1

    def _indisponibilidade_estagiario(self, operador: Operador):
        limites = DadosConfig.LIMITES_DIAS
        if operador.turno == "tarde":
            inicio_rel, fim_rel = 150.0, 480.0
        else:
            inicio_rel, fim_rel = 0.0, DadosConfig.MINUTOS_ESTAGIO_DIA

        for dia in range(6):
            inicio_dia, fim_dia = limites[dia], limites[dia + 1]
            if dia < 5:
                if inicio_rel > 0:
                    espera_pre = inicio_dia - self.env.now
                    if espera_pre > 0:
                        yield self.env.timeout(espera_pre)
                    yield from self._bloquear(operador, inicio_rel)
                inicio_bloqueio, fim_bloqueio = inicio_dia + fim_rel, fim_dia
            else:
                inicio_bloqueio, fim_bloqueio = inicio_dia, fim_dia

            espera = inicio_bloqueio - self.env.now
            if espera > 0:
                yield self.env.timeout(espera)
            duracao = fim_bloqueio - self.env.now
            if duracao > 0:
                yield from self._bloquear(operador, duracao)

    def _indisponibilidade_meio_periodo(self, operador: Operador):
        limites = DadosConfig.LIMITES_DIAS
        janela_ini, janela_fim = 330.0, 480.0
        for dia in range(6):
            inicio_dia, fim_dia = limites[dia], limites[dia + 1]
            if dia < 5:
                espera = inicio_dia - self.env.now
                if espera > 0:
                    yield self.env.timeout(espera)
                yield from self._bloquear(operador, janela_ini)
                espera2 = (inicio_dia + janela_fim) - self.env.now
                if espera2 > 0:
                    yield self.env.timeout(espera2)
            else:
                espera = inicio_dia - self.env.now
                if espera > 0:
                    yield self.env.timeout(espera)
                yield from self._bloquear(operador, fim_dia - inicio_dia)

    # ---------------- balanceamento dinâmico ----------------
    @staticmethod
    def _ajustar_capacidade(resource: simpy.PriorityResource, delta: int) -> None:
        # O SimPy não expõe alteração de capacidade em tempo de execução; a
        # mutação direta representa o operador que troca de posto.
        try:
            resource.capacity += delta
        except AttributeError:
            resource._capacity += delta
        if delta > 0:
            resource._trigger_put(None)

    def _balanceamento_linha(self):
        lim_g = self.regras["limite_fila_gargalo"]
        lim_n = self.regras["limite_fila_normalizacao"]
        while True:
            yield self.env.timeout(5.0)
            fila = len(self.postos["Personalização"].queue)
            if not self._apoio_ativo and fila > lim_g:
                cand = self._selecionar_operador_apoio()
                piso = self.capacidade_minima.get("Etiquetagem", 1)
                if cand is not None and self.postos["Etiquetagem"].capacity > max(1, piso - 1):
                    cand.posto_atual = "Personalização"
                    self._ajustar_capacidade(self.postos["Etiquetagem"], -1)
                    self._ajustar_capacidade(self.postos["Personalização"], +1)
                    self._operador_emprestado = cand
                    self._apoio_ativo = True
            elif self._apoio_ativo and fila <= lim_n:
                cand = self._operador_emprestado
                cand.posto_atual = cand.posto_original
                self._ajustar_capacidade(self.postos["Personalização"], -1)
                self._ajustar_capacidade(self.postos["Etiquetagem"], +1)
                self._operador_emprestado = None
                self._apoio_ativo = False

    def _selecionar_operador_apoio(self) -> Optional[Operador]:
        cands = [op for op in self.operadores
                 if op.posto_original == "Etiquetagem"
                 and op.posto_atual == "Etiquetagem"
                 and op.disponivel]
        if not self.regras.get("polivalencia_ampliada"):
            cands = [op for op in cands if op.tipo_contrato == "CLT"]
        if not cands:
            return None
        return min(cands, key=lambda o: o.tempo_trabalhado)

    # ---------------- tempos ----------------
    def amostrar_tempo_lognormal(self, media_desejada: float) -> float:
        if media_desejada <= 0:
            return 0.0
        cv = self.regras["cv_tempos"]
        var = (media_desejada * cv) ** 2
        mu = math.log(media_desejada ** 2 / math.sqrt(var + media_desejada ** 2))
        sigma = math.sqrt(math.log(var / (media_desejada ** 2) + 1))
        return self.rng_serv.lognormvariate(mu, sigma)

    def obter_tempo_operador(self, posto: str) -> float:
        if posto == "Separação":
            return self.amostrar_tempo_lognormal(DadosConfig.TEMPO_SEPARACAO)
        if posto == "Expedição":
            return self.amostrar_tempo_lognormal(DadosConfig.TEMPO_EXPEDICAO)

        ops = [op for op in self.operadores if op.posto_atual == posto and op.disponivel]
        if not ops:
            ops = [op for op in self.operadores if op.posto_atual == posto]
        if not ops:
            return 2.0
        sel = min(ops, key=lambda x: x.tempo_trabalhado)
        t = self.amostrar_tempo_lognormal(sel.tempo_medio_cenario)
        sel.tempo_trabalhado += t
        return t

    # ---------------- fluxo do pedido ----------------
    def processar_pedido(self, pedido: Pedido):
        self.total_chegados += 1
        self.pedidos_ativos[pedido.id_pedido] = pedido
        self._wip_incr()
        i = 0
        while i < len(FLUXO):
            etapa = FLUXO[i]
            t_in = self.env.now
            with self.postos[etapa].request(priority=pedido.prioridade) as req:
                yield req
                pedido.tempo_total_fila += (self.env.now - t_in)
                t_op = self.obter_tempo_operador(etapa) * (1.0 + 0.1 * (pedido.itens - 1))
                ini = self.env.now
                yield self.env.timeout(t_op)
                self._registra_ocupacao(etapa, ini, self.env.now)
                yield self.env.timeout(self.regras["tempo_deslocamento_base"]
                                       * self.regras["fator_deslocamento"])

            # Não conformidade na Personalização: a peça é substituída na
            # Separação, então o pedido retorna à primeira etapa do fluxo.
            if etapa == "Personalização" and self.rng_ret.random() < self.regras["taxa_retrabalho"]:
                self.contador_retrabalhos += 1
                pedido.retrabalhos_sofridos += 1
                i = 0
            else:
                i += 1

        pedido.tempo_fim = self.env.now
        self._wip_decr()
        self.pedidos_finalizados.append(pedido)
        self.pedidos_ativos.pop(pedido.id_pedido, None)


# ============================== SIMULADOR ==============================

class Simulador:
    def __init__(self, replicacoes: int = 100, nivel_confianca: float = 0.95) -> None:
        self.replicacoes = replicacoes
        self.tempo_semana = DadosConfig.LIMITES_DIAS[-1]
        self.z = {0.90: 1.645, 0.95: 1.96, 0.99: 2.576}.get(round(nivel_confianca, 2), 1.96)

    @staticmethod
    def _montar_rngs(semente: int) -> Dict[str, Any]:
        # Um gerador por fonte estocástica. Assim, mudar o número de sorteios de
        # serviço em um cenário não desloca a sequência de chegadas dos demais,
        # o que preserva o pareamento por números aleatórios comuns.
        return {
            "chegada": random.Random(semente * 10 + 1),
            "servico": random.Random(semente * 10 + 2),
            "retrabalho": random.Random(semente * 10 + 3),
            "prioridade": random.Random(semente * 10 + 4),
            "itens": np.random.default_rng(semente * 10 + 5),
        }

    def gerador_demanda(self, env, empresa, rngs):
        # As chegadas preenchem todo o expediente: o sorteio prossegue enquanto o
        # próximo intervalo couber no dia, sem contagem máxima fixada de antemão.
        rc, rp, ri = rngs["chegada"], rngs["prioridade"], rngs["itens"]
        id_pedido = 1
        limites = DadosConfig.LIMITES_DIAS
        for dia in range(6):
            inicio_dia, fim_dia = limites[dia], limites[dia + 1]
            duracao = fim_dia - inicio_dia
            alvo = rc.randint(70, 120)
            if DadosConfig.DEMANDA_SABADO_PROPORCIONAL:
                alvo = max(1, int(round(alvo * duracao / DadosConfig.MINUTOS_POR_DIA_UTIL)))
            intervalo = duracao / alvo
            while True:
                prox = rc.expovariate(1.0 / intervalo)
                if env.now + prox >= fim_dia:
                    break
                yield env.timeout(prox)
                prioridade = 0 if rp.random() < 0.25 else 1
                itens = 1 + int(ri.poisson(0.5))          # média 1,5, mínimo 1
                env.process(empresa.processar_pedido(
                    Pedido(id_pedido, env.now, prioridade, itens)))
                id_pedido += 1
            resto = fim_dia - env.now
            if resto > 0:
                yield env.timeout(resto)

    def executar_replicacao(self, id_cenario: int, semente: int,
                            params: Dict[str, Any]) -> Dict[str, Any]:
        rngs = self._montar_rngs(semente)
        env = simpy.Environment()
        empresa = EmpresaAlpha(env, id_cenario, params, rngs)
        env.process(self.gerador_demanda(env, empresa, rngs))
        env.run(until=self.tempo_semana)
        empresa._wip_update()

        pedidos = empresa.pedidos_finalizados
        n = len(pedidos)
        T = self.tempo_semana
        lead = float(np.mean([p.tempo_fim - p.tempo_chegada for p in pedidos])) if pedidos else 0.0
        fila = float(np.mean([p.tempo_total_fila for p in pedidos])) if pedidos else 0.0

        # Verificação pela Lei de Little: o WIP médio deve igualar a permanência
        # total (concluídos e pendentes) dividida pela janela. Incluir os pedidos
        # em backlog é o que faz a identidade fechar.
        wip_medido = empresa._wip_area / T
        perm = sum(p.tempo_fim - p.tempo_chegada for p in pedidos)
        perm += sum(T - p.tempo_chegada for p in empresa.pedidos_ativos.values())
        wip_little = perm / T

        util_posto: Dict[str, List[float]] = {}
        for op in empresa.operadores:
            if op.tipo_contrato == "Estágio":
                jmax = DadosConfig.JORNADA_SEMANAL_ESTAGIO
            elif op.tipo_contrato == "MeioPeriodo":
                jmax = DadosConfig.JORNADA_SEMANAL_MEIO_PERIODO
            else:
                jmax = DadosConfig.JORNADA_SEMANAL_CLT
            u = op.tempo_trabalhado / jmax
            if u > 1.0:
                empresa.alertas.append(
                    f"{op.id_operador}: utilização {u*100:.1f}% acima de 100%")
            util_posto.setdefault(op.posto_original, []).append(u)
        util_media = {p: float(np.mean(v)) for p, v in util_posto.items()}
        posto_top = max(util_media, key=util_media.get) if util_media else "Nenhum"

        limites = DadosConfig.LIMITES_DIAS
        no_prazo = 0
        for p in pedidos:
            for d in range(6):
                if limites[d] <= p.tempo_chegada < limites[d + 1]:
                    if p.tempo_fim <= limites[d + 1]:
                        no_prazo += 1
                    break
        ns_concl = no_prazo / n if n else 0.0
        ns_cheg = no_prazo / empresa.total_chegados if empresa.total_chegados else 0.0

        return {
            "producao": n, "lead_time": lead, "tempo_fila": fila,
            "wip_medido": wip_medido, "wip_little": wip_little,
            "util_global": float(np.mean(list(util_media.values()))) if util_media else 0.0,
            "util_perso": util_media.get("Personalização", 0.0),
            "util_etiq": util_media.get("Etiquetagem", 0.0),
            "util_emb": util_media.get("Embalagem", 0.0),
            "retrabalhos": empresa.contador_retrabalhos, "posto_top": posto_top,
            "chegados": empresa.total_chegados, "backlog": empresa.total_chegados - n,
            "score": n / lead if lead > 0 else 0.0,
            "ns_concluidos": ns_concl, "ns_chegados": ns_cheg,
            "_ocupacao": empresa.ocupacao, "_cap_bucket": empresa.cap_bucket,
            "_alertas": empresa.alertas,
        }

    def rodar(self, params: Optional[Dict[str, Any]] = None,
              cenarios=(1, 6, 7, 8), guardar_perfil: bool = False) -> Dict[Any, Dict[str, List]]:
        params = params or {}
        sementes = [1000 + k for k in range(self.replicacoes)]
        chaves = ["producao", "lead_time", "tempo_fila", "wip_medido", "wip_little",
                  "util_global", "util_perso", "util_etiq", "util_emb",
                  "retrabalhos", "backlog", "chegados", "score", "posto_top",
                  "ns_concluidos", "ns_chegados"]
        nb = int(math.ceil(DadosConfig.LIMITES_DIAS[-1] / BUCKET))
        out = {}
        for c in cenarios:
            acc = {k: [] for k in chaves}
            perfil_oc = {p: np.zeros(nb) for p in POSTOS_LIMITADOS}
            perfil_cap = {p: np.zeros(nb) for p in POSTOS_LIMITADOS}
            alertas = []
            for k in range(self.replicacoes):
                m = self.executar_replicacao(c, sementes[k], params)
                for key in chaves:
                    acc[key].append(m[key])
                alertas.extend(m["_alertas"])
                if guardar_perfil:
                    for p in POSTOS_LIMITADOS:
                        perfil_oc[p] += m["_ocupacao"][p]
                        perfil_cap[p] += m["_cap_bucket"][p]
            if guardar_perfil:
                acc["_perfil_oc"] = {p: perfil_oc[p] / self.replicacoes for p in POSTOS_LIMITADOS}
                acc["_perfil_cap"] = {p: perfil_cap[p] / self.replicacoes for p in POSTOS_LIMITADOS}
            acc["_alertas"] = alertas
            out[c] = acc
        return out


# ============================== ESTATÍSTICA ==============================

def stats(v, z=1.96):
    a = np.asarray(v, float)
    m = float(a.mean())
    dp = float(a.std(ddof=1)) if len(a) > 1 else 0.0
    ep = dp / math.sqrt(len(a)) if len(a) else 0.0
    return dict(media=m, dp=dp, ep=ep, ic=z * ep)


NOMES = {
    0: "C0 Controle (jornada homogênea)",
    1: "C1 Situação Atual",
    2: "C2 Estudo de Tempos",
    3: "C3 Novo Layout",
    4: "C4 Balanceamento Enxuto",
    5: "C5 Expansão (11º op)",
    6: "C6 Tempos + Layout",
    7: "C7 Lean Completo",
    8: "C8 Lean + Expansão",
    9: "C9 Turnos Escalonados",
    10: "C10 Contratação Parcial",
    "H1": "H1 C6 com retrabalho 5%",
    "H2": "H2 C7 com polivalência ampliada",
    "B5a": "C1 com Separação cap=1",
    "B5b": "C1 com Separação cap=2",
}


def tabela_comparativa(res, cenarios, titulo="TABELA COMPARATIVA"):
    from collections import Counter
    linhas = []
    for c in cenarios:
        a = res[c]
        p, l, f, w, s = (stats(a['producao']), stats(a['lead_time']), stats(a['tempo_fila']),
                         stats(a['wip_medido']), stats(a['score']))
        u = stats(a['util_global'])
        bk = 100 * np.mean(a['backlog']) / np.mean(a['chegados'])
        linhas.append([
            NOMES.get(c, str(c)),
            f"{p['media']:.1f}±{p['ic']:.1f}",
            f"{l['media']:.2f}±{l['ic']:.2f}",
            f"{f['media']:.2f}±{f['ic']:.2f}",
            f"{w['media']:.2f}±{w['ic']:.2f}",
            f"{s['media']:.2f}±{s['ic']:.2f}",
            f"{u['media']*100:.2f}%",
            f"{bk:.1f}%",
            f"{100*np.mean(a['ns_concluidos']):.1f}%",
            f"{100*np.mean(a['ns_chegados']):.1f}%",
            Counter(a['posto_top']).most_common(1)[0][0],
        ])
    df = pd.DataFrame(linhas, columns=["Cenário", "Produção", "Lead Time", "Fila", "WIP",
                                       "Score", "Utilização", "Backlog",
                                       "NS/concl.", "NS/cheg.", "Posto+ocupado"])
    print(f"\n===== {titulo} =====")
    print(df.to_string(index=False))
    return df


def verificacao_little(res, cenarios=(1, 6, 9)):
    print("\n===== VERIFICAÇÃO PELA LEI DE LITTLE =====")
    for c in cenarios:
        if c not in res:
            continue
        lm = np.mean(res[c]['wip_medido'])
        ll = np.mean(res[c]['wip_little'])
        dif = 100 * abs(lm - ll) / ll if ll else 0.0
        print(f"  {NOMES.get(c, str(c)):<26} WIP medido={lm:.3f}  L=λ·W={ll:.3f}  "
              f"diferença={dif:.2f}%")


def utilizacao_por_posto(res, cenarios=(1, 6, 8)):
    print("\n===== UTILIZAÇÃO POR POSTO =====")
    for c in cenarios:
        if c not in res:
            continue
        r = res[c]
        print(f"  {NOMES.get(c, str(c)):<26} "
              f"Perso {100*np.mean(r['util_perso']):5.1f}%   "
              f"Etiq {100*np.mean(r['util_etiq']):5.1f}%   "
              f"Emb {100*np.mean(r['util_emb']):5.1f}%")


def relatorio_controle(res):
    if 0 not in res or 1 not in res:
        return
    f0, f1 = stats(res[0]['tempo_fila']), stats(res[1]['tempo_fila'])
    print("\n===== CENÁRIO DE CONTROLE (JORNADA HOMOGÊNEA) =====")
    print(f"  Espera em fila — C1 (jornadas assimétricas): {f1['media']:.2f} ± {f1['ic']:.2f} min")
    print(f"  Espera em fila — C0 (jornada homogênea)    : {f0['media']:.2f} ± {f0['ic']:.2f} min")
    if f1['media'] > 0:
        print(f"  Diferença atribuível à descontinuidade de jornada: "
              f"{f1['media']-f0['media']:.2f} min "
              f"({100*(f1['media']-f0['media'])/f1['media']:.1f}% da espera atual)")


def testes_hipotese(res, base=6, alvos=(1, 7, 8, 9, 10, "H1", "H2")):
    if not SCIPY:
        print("[scipy indisponível — testes não executados]")
        return
    print(f"\n===== TESTE t PAREADO (CRN) — Score, contra {NOMES[base]} =====")
    b = np.array(res[base]['score'])
    for c in alvos:
        if c not in res:
            continue
        x = np.array(res[c]['score'])
        t, p = sps.ttest_rel(x, b)
        sig = "significativo" if p < 0.05 else "sem diferença significativa"
        print(f"  {NOMES.get(c, str(c)):<34} dScore={x.mean()-b.mean():+7.3f}  "
              f"t={t:8.3f}  p={p:.4f}  ({sig})")

    print(f"\n===== TESTE t PAREADO (CRN) — Nível de serviço sobre chegados =====")
    b = np.array(res[base]['ns_chegados'])
    for c in alvos:
        if c not in res:
            continue
        x = np.array(res[c]['ns_chegados'])
        t, p = sps.ttest_rel(x, b)
        sig = "significativo" if p < 0.05 else "sem diferença significativa"
        print(f"  {NOMES.get(c, str(c)):<34} dNS={100*(x.mean()-b.mean()):+6.2f}pp  "
              f"t={t:8.3f}  p={p:.4f}  ({sig})")


def comparar_c9_c10(res):
    if not SCIPY or 9 not in res or 10 not in res:
        return
    print("\n===== CENÁRIO 9 vs CENÁRIO 10 (teste t pareado) =====")
    for k, rot in [('score', 'Score'), ('lead_time', 'Lead Time'),
                   ('ns_chegados', 'NS sobre chegados')]:
        a, b = np.array(res[9][k]), np.array(res[10][k])
        t, p = sps.ttest_rel(a, b)
        sig = "significativo" if p < 0.05 else "sem diferença significativa"
        print(f"  {rot:<20} C9={a.mean():.4f}  C10={b.mean():.4f}  p={p:.4f}  ({sig})")


# ============================== FIGURAS ==============================

def fig_indicadores(res, cenarios=(1, 6, 7, 8, 9, 10), arquivo="fig_score_leadtime_wip.png"):
    rot = [NOMES.get(c, str(c)).split()[0] for c in cenarios]
    fig, ax = plt.subplots(1, 3, figsize=(15, 4.2))
    for a, key, tit, cor in [
            (ax[0], 'score', 'Score de Eficiência Global', '#1f77b4'),
            (ax[1], 'lead_time', 'Lead Time Médio (min)', '#ff7f0e'),
            (ax[2], 'wip_medido', 'WIP Médio (pedidos)', '#2ca02c')]:
        m = [np.mean(res[c][key]) for c in cenarios]
        e = [stats(res[c][key])['ic'] for c in cenarios]
        a.bar(rot, m, yerr=e, capsize=4, color=cor)
        a.set_title(tit)
        a.grid(axis='y', alpha=.3)
    plt.tight_layout()
    plt.savefig(arquivo, dpi=150)
    print(f"\n[figura] {arquivo}")


def fig_score_nivel_servico(res, cenarios=(1, 6, 7, 8, 9, 10),
                            arquivo="fig_score_nivel_servico.png"):
    rot = [NOMES.get(c, str(c)).split()[0] for c in cenarios]
    x = np.arange(len(cenarios))
    fig, ax = plt.subplots(1, 2, figsize=(13, 4.2))

    m = [np.mean(res[c]['score']) for c in cenarios]
    e = [stats(res[c]['score'])['ic'] for c in cenarios]
    ax[0].bar(rot, m, yerr=e, capsize=4, color='#1f77b4')
    ax[0].set_title('Score de Eficiência Global (IC 95%)')
    ax[0].grid(axis='y', alpha=.3)

    ns_c = [100 * np.mean(res[c]['ns_concluidos']) for c in cenarios]
    ns_g = [100 * np.mean(res[c]['ns_chegados']) for c in cenarios]
    w = 0.38
    ax[1].bar(x - w / 2, ns_c, w, label='sobre concluídos', color='#2ca02c')
    ax[1].bar(x + w / 2, ns_g, w, label='sobre chegados', color='#9edae5')
    ax[1].axhline(98, color='red', ls='--', lw=1, label='meta: 98%')
    ax[1].set_xticks(x)
    ax[1].set_xticklabels(rot)
    ax[1].set_ylim(80, 100)
    ax[1].legend(fontsize=8)
    ax[1].set_title('Nível de Serviço (% no mesmo dia)')
    ax[1].grid(axis='y', alpha=.3)
    plt.tight_layout()
    plt.savefig(arquivo, dpi=150)
    print(f"[figura] {arquivo}")


def fig_perfil_intradiario(res, cenarios=(1, 9), arquivo="perfil_intradiario.png"):
    limites = DadosConfig.LIMITES_DIAS
    nb_dia = int(DadosConfig.MINUTOS_POR_DIA_UTIL / BUCKET)
    fig, axes = plt.subplots(1, len(cenarios), figsize=(7 * len(cenarios), 4.2), sharey=True)
    if len(cenarios) == 1:
        axes = [axes]
    for ax, c in zip(axes, cenarios):
        if "_perfil_oc" not in res[c]:
            continue
        for p in POSTOS_LIMITADOS:
            oc, cap = res[c]["_perfil_oc"][p], res[c]["_perfil_cap"][p]
            soma_oc, soma_cap = np.zeros(nb_dia), np.zeros(nb_dia)
            for dia in range(5):
                b0 = int(limites[dia] / BUCKET)
                soma_oc += oc[b0:b0 + nb_dia]
                soma_cap += cap[b0:b0 + nb_dia]
            util = np.divide(soma_oc, soma_cap * BUCKET,
                             out=np.zeros(nb_dia), where=soma_cap > 0)
            horas = [8 + (i * BUCKET) / 60 for i in range(nb_dia)]
            ax.plot(horas, 100 * util, marker='o', ms=3, label=p)
        ax.axvline(13.5, color='red', ls='--', lw=1, label='saída dos estagiários')
        ax.set_title(NOMES.get(c, str(c)))
        ax.set_xlabel('hora do dia')
        ax.grid(alpha=.3)
    axes[0].set_ylabel('utilização do posto (%)')
    axes[0].legend(fontsize=8)
    plt.tight_layout()
    plt.savefig(arquivo, dpi=150)
    print(f"[figura] {arquivo}")


# ============================== ROTINAS COMPLEMENTARES ==============================

def analise_sensibilidade(replicacoes=30, cenarios=(1, 6, 7, 8, 9, 10)):
    grade = ([("taxa_retrabalho", v) for v in (0.05, 0.10, 0.15)]
             + [("cv_tempos", v) for v in (0.10, 0.15, 0.20)]
             + [("limite_fila_gargalo", v) for v in (2, 3, 5)])
    sim = Simulador(replicacoes=replicacoes)
    linhas = []
    for par, val in grade:
        r = sim.rodar(params={par: val}, cenarios=cenarios)
        for c in cenarios:
            linhas.append({
                "parâmetro": par, "valor": val, "cenário": NOMES.get(c, str(c)),
                "Score": round(float(np.mean(r[c]['score'])), 2),
                "Lead Time": round(float(np.mean(r[c]['lead_time'])), 2),
                "NS_chegados": round(100 * float(np.mean(r[c]['ns_chegados'])), 1),
            })
    df = pd.DataFrame(linhas)
    print("\n===== ANÁLISE DE SENSIBILIDADE (Score) =====")
    print(df.pivot_table(index=["parâmetro", "valor"], columns="cenário",
                         values="Score").round(2).to_string())
    df.to_csv("sensibilidade.csv", index=False)
    print("[arquivo] sensibilidade.csv")
    return df


def teste_separacao_restritiva(replicacoes=100):
    sim = Simulador(replicacoes=replicacoes)
    todos = {
        1: sim.rodar(cenarios=[1])[1],
        "B5a": sim.rodar(params={"cap_separacao": 1}, cenarios=[1])[1],
        "B5b": sim.rodar(params={"cap_separacao": 2}, cenarios=[1])[1],
    }
    return tabela_comparativa(todos, [1, "B5a", "B5b"],
                              "SENSIBILIDADE À CAPACIDADE DA SEPARAÇÃO")


# ============================== EXECUÇÃO ==============================

def main(replicacoes=100, com_sensibilidade=True, com_separacao=True):
    sim = Simulador(replicacoes=replicacoes, nivel_confianca=0.95)

    print(f"Executando {replicacoes} réplicas por cenário...")
    principais = list(range(0, 11))
    res = sim.rodar(cenarios=principais, guardar_perfil=True)
    res["H1"] = sim.rodar(params={"taxa_retrabalho": 0.05}, cenarios=[6])[6]
    res["H2"] = sim.rodar(params={"polivalencia_ampliada": True}, cenarios=[7])[7]

    alertas = [a for c in res.values() for a in (c.get("_alertas", []) if isinstance(c, dict) else [])]
    if alertas:
        print(f"\n[AVISO] {len(alertas)} registro(s) de utilização acima de 100%:")
        for a in alertas[:5]:
            print("   ", a)
    else:
        print("\nNenhuma utilização acima de 100% — jornadas consistentes.")

    tabela_comparativa(res, principais + ["H1", "H2"])
    verificacao_little(res)
    utilizacao_por_posto(res)
    relatorio_controle(res)
    testes_hipotese(res)
    comparar_c9_c10(res)

    fig_indicadores(res)
    fig_score_nivel_servico(res)
    fig_perfil_intradiario(res, cenarios=(1, 9))

    if com_separacao:
        teste_separacao_restritiva(replicacoes=replicacoes)
    if com_sensibilidade:
        analise_sensibilidade(replicacoes=max(20, replicacoes // 3))

    print("\nConcluído.")
    return res


if __name__ == "__main__":
    resultados = main(replicacoes=100)
