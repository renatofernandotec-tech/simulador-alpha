import math
import random
from dataclasses import dataclass, field
from typing import Dict, List, Tuple, Any, Optional

import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import simpy

@dataclass
class Pedido:
    """Representa uma unidade de demanda (pedido) fluindo pela linha."""

    id_pedido: int
    tempo_chegada: float
    prioridade: int  # 0 = Expresso (alta prioridade), 1 = Normal
    itens: int = field(default=1)
    tempo_total_fila: float = field(default=0.0)
    tempo_fim: float = field(default=0.0)
    retrabalhos_sofridos: int = field(default=0)

    def __lt__(self, other: "Pedido") -> bool:
        # Necessário para o PriorityResource desempatar pedidos de mesma prioridade
        return self.prioridade < other.prioridade


@dataclass
class Operador:
    """Representa um operador real da linha (CLT ou Estágio)."""

    id_operador: str
    posto_original: str
    tempo_medio_base: float
    eficiencia_base: float
    tipo_contrato: str  # 'CLT' ou 'Estágio'
    polivalencia: List[str] = field(default_factory=list)

    # Atributos dinâmicos calculados por cenário/execução
    posto_atual: str = field(init=False)
    tempo_medio_cenario: float = field(init=False)
    tempo_trabalhado: float = field(default=0.0)

    def __post_init__(self) -> None:
        self.posto_atual = self.posto_original
        self.tempo_medio_cenario = self.tempo_medio_base

class DadosConfig:

    # --- Jornada de trabalho (minutos) -------------------------------------
    MINUTOS_POR_DIA_UTIL = 480.0       # 8h, segunda a sexta
    MINUTOS_SABADO = 240.0             # 4h, sábado (apenas CLT)
    MINUTOS_ESTAGIO_DIA = 330.0        # 5,5h líquidas/dia útil do estagiário
    JORNADA_SEMANAL_CLT = 2640.0       # 44h = (5*8h) + 4h de sábado
    JORNADA_SEMANAL_ESTAGIO = 1650.0   # 27,5h = 5,5h * 5 dias úteis (sem sábado)

    # Limites (fronteiras absolutas, em minutos) dos 6 dias operacionais da
    # semana: índice 0..4 = Seg a Sex (480 min cada), índice 5 = Sábado (240 min)
    LIMITES_DIAS = [0.0, 480.0, 960.0, 1440.0, 1920.0, 2400.0, 2640.0]

    @staticmethod
    def obter_operadores_base() -> List[Operador]:
        return [
            # Posto: Personalização
            Operador("OP-PR-01", "Personalização", 2.0, 0.833, "CLT"),
            Operador("OP-PR-02", "Personalização", 2.0, 0.667, "CLT", ["Embalagem"]),

            # Posto: Etiquetagem
            Operador("OP-ET-01", "Etiquetagem", 3.0, 0.850, "CLT"),
            Operador("OP-ET-02", "Etiquetagem", 3.5, 0.778, "Estágio", ["Polivalente"]),
            Operador("OP-ET-03", "Etiquetagem", 2.5, 0.875, "Estágio"),
            Operador("OP-ET-04", "Etiquetagem", 2.5, 0.625, "Estágio"),
            Operador("OP-ET-05", "Etiquetagem", 3.0, 0.800, "Estágio"),

            # Posto: Embalagem
            Operador("OP-EM-01", "Embalagem", 1.74, 0.686, "Estágio"),
            Operador("OP-EM-02", "Embalagem", 1.91, 0.677, "CLT"),
            Operador("OP-EM-03", "Embalagem", 2.00, 0.700, "Estágio", ["Etiquetagem"]),
        ]

    @staticmethod
    def configurar_cenario(id_cenario: int, operadores: List[Operador]) -> Tuple[Dict[str, Any], List[Operador]]:
        
        regras: Dict[str, Any] = {
            "fator_deslocamento": 1.0,
            "taxa_retrabalho": 0.10,
            "tempo_deslocamento_base": 0.5,
            "balanceamento_enxuto": False,
            "expansao_capacidade": False,
            "limite_fila_gargalo": 3,       # fila > X pedidos aciona o apoio
            "limite_fila_normalizacao": 1,  # fila <= isso devolve o operador
        }

        mapa_cenarios = {
            1: dict(),
            2: dict(estudo_tempos=True),
            3: dict(novo_layout=True),
            4: dict(balanceamento_enxuto=True),
            5: dict(expansao_capacidade=True),
            6: dict(estudo_tempos=True, novo_layout=True),
            7: dict(estudo_tempos=True, novo_layout=True, balanceamento_enxuto=True),
            8: dict(estudo_tempos=True, novo_layout=True, expansao_capacidade=True),
        }
        flags = mapa_cenarios.get(id_cenario, dict())

        estudo_tempos = flags.get("estudo_tempos", False)
        novo_layout = flags.get("novo_layout", False)
        regras["balanceamento_enxuto"] = flags.get("balanceamento_enxuto", False)
        regras["expansao_capacidade"] = flags.get("expansao_capacidade", False)

        # 1. Estudo de Tempos: padronização eleva eficiência mínima para 85%
        if estudo_tempos:
            for op in operadores:
                op.eficiencia_base = max(op.eficiencia_base, 0.85)

        # 2. Novo Layout: redução drástica nas distâncias / movimentação
        if novo_layout:
            regras["fator_deslocamento"] = 0.50

        # 3. Expansão de Capacidade: contratação real de um 11º operador CLT
        #    dedicado à Personalização (não é balanceamento - é headcount novo)
        if regras["expansao_capacidade"]:
            operadores.append(
                Operador("OP-EXP-01", "Personalização", 2.0, 0.833, "CLT")
            )

        # Ajuste do tempo médio real considerando a eficiência de cada operador
        for op in operadores:
            op.tempo_medio_cenario = op.tempo_medio_base / op.eficiencia_base

        return regras, operadores

class EmpresaAlpha:

    def __init__(self, env: simpy.Environment, id_cenario: int) -> None:
        self.env = env
        self.id_cenario = id_cenario

        operadores_base = DadosConfig.obter_operadores_base()
        self.regras, self.operadores = DadosConfig.configurar_cenario(id_cenario, operadores_base)

        self.alocacao_postos = self._calcular_capacidade_postos()
        # Piso de segurança usado pelo balanceamento (nunca esvaziar um posto)
        self.capacidade_minima = dict(self.alocacao_postos)

        self.postos: Dict[str, simpy.PriorityResource] = {
            "Separação": simpy.PriorityResource(env, capacity=999),
            "Personalização": simpy.PriorityResource(env, capacity=self.alocacao_postos["Personalização"]),
            "Etiquetagem": simpy.PriorityResource(env, capacity=self.alocacao_postos["Etiquetagem"]),
            "Embalagem": simpy.PriorityResource(env, capacity=self.alocacao_postos["Embalagem"]),
            "Expedição": simpy.PriorityResource(env, capacity=999),
        }

        self.pedidos_finalizados: List[Pedido] = []
        self.contador_retrabalhos: int = 0

        # --- RESTRIÇÃO ATIVA DE JORNADA DOS ESTAGIÁRIOS ---------------------
        # Cada estagiário "ocupa" ativamente uma vaga de capacidade do seu
        # posto durante as janelas em que não pode trabalhar (após 330 min
        # em dias úteis e durante todo o sábado). Isso reduz a capacidade
        # REAL disponível no relógio do SimPy, e não apenas no pós-processo.
        for op in self.operadores:
            if op.tipo_contrato == "Estágio":
                env.process(self._processo_indisponibilidade_estagiario(op))

        # --- BALANCEAMENTO ENXUTO (realocação dinâmica, sem contratação) ---
        self._apoio_ativo = False
        self._operador_emprestado: Optional[Operador] = None
        if self.regras["balanceamento_enxuto"]:
            env.process(self._processo_balanceamento_linha())

    # -------------------------------------------------------------------
    def _calcular_capacidade_postos(self) -> Dict[str, int]:
        capacidades = {"Separação": 999, "Personalização": 0, "Etiquetagem": 0, "Embalagem": 0, "Expedição": 999}
        for op in self.operadores:
            if op.posto_atual in capacidades:
                capacidades[op.posto_atual] += 1

        # Garante o mínimo de 1 operador por posto para evitar travamento
        for posto in capacidades:
            if capacidades[posto] == 0:
                capacidades[posto] = 1
        return capacidades

    # -------------------------------------------------------------------
    def _processo_indisponibilidade_estagiario(self, operador: Operador):
        
        limites = DadosConfig.LIMITES_DIAS
        for dia in range(6):
            inicio_dia, fim_dia = limites[dia], limites[dia + 1]

            if dia < 5:
                inicio_bloqueio = inicio_dia + DadosConfig.MINUTOS_ESTAGIO_DIA
                fim_bloqueio = fim_dia
            else:
                # Sábado: estagiário não é escalado - dia inteiro bloqueado
                inicio_bloqueio = inicio_dia
                fim_bloqueio = fim_dia

            espera = inicio_bloqueio - self.env.now
            if espera > 0:
                yield self.env.timeout(espera)

            duracao_bloqueio = fim_bloqueio - self.env.now
            if duracao_bloqueio <= 0:
                continue

            # Usa o posto ATUAL do operador (respeita empréstimo em curso,
            # caso o balanceamento enxuto o tenha realocado temporariamente)
            posto_alvo = operador.posto_atual
            with self.postos[posto_alvo].request(priority=-1) as req:
                yield req
                yield self.env.timeout(duracao_bloqueio)

    # -------------------------------------------------------------------
    @staticmethod
    def _ajustar_capacidade(resource: simpy.PriorityResource, delta: int) -> None:
        
        try:
            resource.capacity += delta
        except AttributeError:
            resource._capacity += delta
        if delta > 0:
            resource._trigger_put(None)

    def _processo_balanceamento_linha(self):

        limite_gargalo = self.regras["limite_fila_gargalo"]
        limite_normalizacao = self.regras["limite_fila_normalizacao"]

        while True:
            yield self.env.timeout(5.0)
            fila_personalizacao = len(self.postos["Personalização"].queue)

            if not self._apoio_ativo and fila_personalizacao > limite_gargalo:
                candidato = self._selecionar_operador_apoio()
                piso_etiquetagem = self.capacidade_minima.get("Etiquetagem", 1)
                pode_emprestar = candidato is not None and self.postos["Etiquetagem"].capacity > max(1, piso_etiquetagem - 1)

                if pode_emprestar:
                    candidato.posto_atual = "Personalização"
                    self._ajustar_capacidade(self.postos["Etiquetagem"], -1)
                    self._ajustar_capacidade(self.postos["Personalização"], +1)
                    self._operador_emprestado = candidato
                    self._apoio_ativo = True

            elif self._apoio_ativo and fila_personalizacao <= limite_normalizacao:
                candidato = self._operador_emprestado
                candidato.posto_atual = candidato.posto_original
                self._ajustar_capacidade(self.postos["Personalização"], -1)
                self._ajustar_capacidade(self.postos["Etiquetagem"], +1)
                self._operador_emprestado = None
                self._apoio_ativo = False

    def _selecionar_operador_apoio(self) -> Optional[Operador]:

        candidatos = [
            op for op in self.operadores
            if op.posto_original == "Etiquetagem"
            and op.posto_atual == "Etiquetagem"
            and op.tipo_contrato == "CLT"
        ]
        if not candidatos:
            return None
        return min(candidatos, key=lambda o: o.tempo_trabalhado)

    # -------------------------------------------------------------------
    def amostrar_tempo_lognormal(self, media_desejada: float) -> float:
        if media_desejada <= 0:
            return 0.0
        desvio_desejado = media_desejada * 0.15

        variancia = desvio_desejado ** 2
        mu = math.log(media_desejada ** 2 / math.sqrt(variancia + media_desejada ** 2))
        sigma = math.sqrt(math.log(variancia / (media_desejada ** 2) + 1))

        return random.lognormvariate(mu, sigma)

    def obter_tempo_operador(self, posto: str) -> float:
        ops_no_posto = [op for op in self.operadores if op.posto_atual == posto]
        if not ops_no_posto:
            return 2.0  # Fallback de segurança acadêmica

        op_selecionado = min(ops_no_posto, key=lambda x: x.tempo_trabalhado)
        tempo_base = op_selecionado.tempo_medio_cenario

        tempo_estocastico = self.amostrar_tempo_lognormal(tempo_base)
        op_selecionado.tempo_trabalhado += tempo_estocastico
        return tempo_estocastico

    def processar_pedido(self, pedido: Pedido):
        fluxo_etapas = ["Separação", "Personalização", "Etiquetagem", "Embalagem", "Expedição"]
        i = 0

        while i < len(fluxo_etapas):
            etapa_atual = fluxo_etapas[i]
            tempo_entrada_fila = self.env.now

            with self.postos[etapa_atual].request(priority=pedido.prioridade) as req:
                yield req

                tempo_saida_fila = self.env.now
                pedido.tempo_total_fila += (tempo_saida_fila - tempo_entrada_fila)

                tempo_operacao = self.obter_tempo_operador(etapa_atual) * (1.0 + 0.1 * (pedido.itens - 1))
                yield self.env.timeout(tempo_operacao)

                tempo_deslocamento = self.regras["tempo_deslocamento_base"] * self.regras["fator_deslocamento"]
                yield self.env.timeout(tempo_deslocamento)

            if etapa_atual == "Personalização" and random.random() < self.regras["taxa_retrabalho"]:
                self.contador_retrabalhos += 1
                pedido.retrabalhos_sofridos += 1
                i = 1
            else:
                i += 1

        pedido.tempo_fim = self.env.now
        self.pedidos_finalizados.append(pedido)

class Simulador:

    def __init__(self, replicaçoes: int = 100, nivel_confianca: float = 0.95) -> None:
        self.replicaçoes = replicaçoes
        # Jornada semanal total (minutos), alinhada ao último limite de dia
        self.tempo_simulaçao_semana = DadosConfig.LIMITES_DIAS[-1]
        self.nivel_confianca = nivel_confianca
        self.z_score = self._obter_z_score(nivel_confianca)

    @staticmethod
    def _obter_z_score(nivel_confianca: float) -> float:
        """Escore z (aproximação normal) para o nível de confiança desejado.
        Para n=100 replicações, a aproximação normal é adequada (n > 30)."""
        tabela_z = {0.90: 1.645, 0.95: 1.96, 0.99: 2.576}
        return tabela_z.get(round(nivel_confianca, 2), 1.96)

    def calcular_estatisticas(self, dados: List[float]) -> Dict[str, float]:
        """Calcula média, desvio padrão amostral, erro padrão e IC 95%
        para uma lista de observações (uma por replicação)."""
        arr = np.asarray(dados, dtype=float)
        media = float(np.mean(arr))
        desvio = float(np.std(arr, ddof=1)) if len(arr) > 1 else 0.0
        erro_padrao = desvio / math.sqrt(len(arr)) if len(arr) > 0 else 0.0
        margem_erro = self.z_score * erro_padrao
        return {
            "media": media,
            "desvio_padrao": desvio,
            "erro_padrao": erro_padrao,
            "ic_inferior": media - margem_erro,
            "ic_superior": media + margem_erro,
            "margem_erro": margem_erro,
        }

    def gerador_demanda(self, env: simpy.Environment, empresa: EmpresaAlpha):
        
        id_pedido = 1
        limites = DadosConfig.LIMITES_DIAS

        for dia in range(6):
            tempo_limite_dia = limites[dia + 1] - limites[dia]  # 480 (seg-sex) ou 240 (sáb)

            total_pedidos_dia = random.randint(70, 120)

            if total_pedidos_dia > 0:
                intervalo_medio = tempo_limite_dia / total_pedidos_dia
                tempo_acumulado_dia = 0.0

                for _ in range(total_pedidos_dia):
                    proxima_chegada = random.expovariate(1.0 / intervalo_medio)
                    tempo_acumulado_dia += proxima_chegada

                    if tempo_acumulado_dia > tempo_limite_dia:
                        break

                    yield env.timeout(proxima_chegada)

                    prioridade = 0 if random.random() < 0.25 else 1
                    itens = max(1, int(np.random.poisson(1.5)))

                    novo_pedido = Pedido(
                        id_pedido=id_pedido,
                        tempo_chegada=env.now,
                        prioridade=prioridade,
                        itens=itens,
                    )
                    env.process(empresa.processar_pedido(novo_pedido))
                    id_pedido += 1

            # Alinha o relógio ao limite absoluto do dia (mantém a
            # granularidade em minutos internamente e a fidelidade aos
            # turnos diários/semanais da metodologia)
            resto = limites[dia + 1] - env.now
            if resto > 0:
                yield env.timeout(resto)

    def executar_replicaçao(self, id_cenario: int) -> Dict[str, Any]:
        env = simpy.Environment()
        empresa = EmpresaAlpha(env, id_cenario)

        env.process(self.gerador_demanda(env, empresa))
        env.run(until=self.tempo_simulaçao_semana)

        pedidos = empresa.pedidos_finalizados
        WIP_estimado = (
            (len(pedidos) * np.mean([p.tempo_fim - p.tempo_chegada for p in pedidos])) / self.tempo_simulaçao_semana
            if pedidos else 0.0
        )

        # Identificação de gargalo por utilização agregada dos operadores
        utilizaçao_por_posto: Dict[str, List[float]] = {}
        for op in empresa.operadores:
            jornada_maxima = (
                DadosConfig.JORNADA_SEMANAL_ESTAGIO if op.tipo_contrato == "Estágio"
                else DadosConfig.JORNADA_SEMANAL_CLT
            )
            taxa = min(1.0, op.tempo_trabalhado / jornada_maxima)
            utilizaçao_por_posto.setdefault(op.posto_original, []).append(taxa)

        utilizaçao_media_posto = {posto: np.mean(taxas) for posto, taxas in utilizaçao_por_posto.items()}
        gargalo_identificado = (
            max(utilizaçao_media_posto, key=utilizaçao_media_posto.get) if utilizaçao_media_posto else "Nenhum"
        )

        return {
            "produçao": len(pedidos),
            "lead_time": np.mean([p.tempo_fim - p.tempo_chegada for p in pedidos]) if pedidos else 0.0,
            "tempo_fila": np.mean([p.tempo_total_fila for p in pedidos]) if pedidos else 0.0,
            "wip": WIP_estimado,
            "utilizaçao_operadores": np.mean(list(utilizaçao_media_posto.values())) if utilizaçao_media_posto else 0.0,
            "retrabalhos": empresa.contador_retrabalhos,
            "gargalo": gargalo_identificado,
        }

    def rodar_cenarios(self) -> Dict[int, Dict[str, Any]]:
        resultados_finais: Dict[int, Dict[str, Any]] = {}

        for cenario in range(1, 9):
            res_acumulados = {
                "produçao": [], "lead_time": [], "tempo_fila": [],
                "wip": [], "utilizaçao_operadores": [], "retrabalhos": [], "gargalo": [],
            }

            for _ in range(self.replicaçoes):
                metricas = self.executar_replicaçao(cenario)
                for k in res_acumulados.keys():
                    res_acumulados[k].append(metricas[k])

            gargalos_lista = res_acumulados["gargalo"]
            gargalo_predominante = max(set(gargalos_lista), key=gargalos_lista.count)

            resultado_cenario = {
                "Produção Semanal": np.mean(res_acumulados["produçao"]),
                "Lead Time Médio (min)": np.mean(res_acumulados["lead_time"]),
                "Tempo em Fila (min)": np.mean(res_acumulados["tempo_fila"]),
                "WIP Médio (pedidos)": np.mean(res_acumulados["wip"]),
                "Utilização Média": np.mean(res_acumulados["utilizaçao_operadores"]),
                "Retrabalhos": np.mean(res_acumulados["retrabalhos"]),
                "Gargalo Identificado": gargalo_predominante,
            }

            mapa_nomes = {
                "produçao": "Produção Semanal",
                "lead_time": "Lead Time Médio (min)",
                "tempo_fila": "Tempo em Fila (min)",
                "wip": "WIP Médio (pedidos)",
                "utilizaçao_operadores": "Utilização Média",
                "retrabalhos": "Retrabalhos",
            }
            for chave, nome_coluna in mapa_nomes.items():
                stats = self.calcular_estatisticas(res_acumulados[chave])
                resultado_cenario[f"{nome_coluna} (DP)"] = stats["desvio_padrao"]
                resultado_cenario[f"{nome_coluna} (EP)"] = stats["erro_padrao"]
                resultado_cenario[f"{nome_coluna} (IC95%)"] = stats["margem_erro"]
                resultado_cenario[f"{nome_coluna} (IC Inf)"] = stats["ic_inferior"]
                resultado_cenario[f"{nome_coluna} (IC Sup)"] = stats["ic_superior"]

            resultados_finais[cenario] = resultado_cenario

        return resultados_finais

class Indicadores:

    def __init__(self, dados_cenarios: Dict[int, Dict[str, Any]]) -> None:
        self.df = pd.DataFrame.from_dict(dados_cenarios, orient='index')
        self.df.index.name = 'Cenário'
        self.nomes_cenarios = {
            1: "1. Situação Atual",
            2: "2. Estudo de Tempos",
            3: "3. Novo Layout",
            4: "4. Balanceamento Enxuto (sem custo)",
            5: "5. Expansão de Capacidade (contratação)",
            6: "6. Tempos + Layout",
            7: "7. Lean Completo (Tempos+Layout+Balanceamento | sem custo)",
            8: "8. Lean + Expansão (Tempos+Layout+Contratação | com custo)",
        }
        self.df['Nome Cenário'] = self.df.index.map(self.nomes_cenarios)

        self.df['Score Eficiência'] = self.df['Produção Semanal'] / self.df['Lead Time Médio (min)']

        self.colunas_principais = [
            'Nome Cenário', 'Produção Semanal', 'Lead Time Médio (min)',
            'Tempo em Fila (min)', 'WIP Médio (pedidos)', 'Utilização Média',
            'Retrabalhos', 'Gargalo Identificado', 'Score Eficiência',
        ]

        self.colunas_dp_ep_ic = []
        for base in ['Produção Semanal', 'Lead Time Médio (min)', 'Tempo em Fila (min)',
                     'WIP Médio (pedidos)', 'Utilização Média', 'Retrabalhos']:
            self.colunas_dp_ep_ic += [f"{base} (DP)", f"{base} (EP)", f"{base} (IC95%)"]

        colunas_totais = self.colunas_principais + [c for c in self.colunas_dp_ep_ic if c in self.df.columns]
        self.df = self.df[colunas_totais]

    def exibir_tabela_comparativa(self) -> None:
        print("\n" + "=" * 110)
        print("          TABELA COMPARATIVA DE CENÁRIOS - SIMULAÇÃO DE EVENTOS DISCRETOS (ANÁLISE LEAN)")
        print("=" * 110)
        print(self.df[self.colunas_principais].to_string(index=False, formatters={
            'Produção Semanal': '{:,.1f}'.format,
            'Lead Time Médio (min)': '{:,.2f}'.format,
            'Tempo em Fila (min)': '{:,.2f}'.format,
            'WIP Médio (pedidos)': '{:,.2f}'.format,
            'Utilização Média': '{:.2%}'.format,
            'Retrabalhos': '{:,.1f}'.format,
            'Score Eficiência': '{:,.3f}'.format,
        }))
        print("=" * 110)

    def exibir_tabela_intervalos_confianca(self) -> None:
        print("\n" + "=" * 110)
        print("          INTERVALOS DE CONFIANÇA (95%) POR CENÁRIO")
        print("=" * 110)

        metricas_base = ['Produção Semanal', 'Lead Time Médio (min)', 'Tempo em Fila (min)',
                          'WIP Médio (pedidos)', 'Utilização Média', 'Retrabalhos']

        for cenario_id, linha in self.df.iterrows():
            print(f"\n--- {linha['Nome Cenário']} ---")
            for metrica in metricas_base:
                media = linha[metrica]
                dp = linha.get(f"{metrica} (DP)")
                ep = linha.get(f"{metrica} (EP)")
                ic = linha.get(f"{metrica} (IC95%)")
                if dp is None:
                    continue
                if metrica == 'Utilização Média':
                    print(f"  {metrica:<26s}: {media:.2%} ± {ic:.2%}  (DP={dp:.2%} | EP={ep:.2%})")
                else:
                    print(f"  {metrica:<26s}: {media:,.2f} ± {ic:,.2f}  (DP={dp:,.2f} | EP={ep:,.2f})")
        print("\n" + "=" * 110)

    def exibir_conversao_turnos(self) -> None:
        
        print("\n" + "=" * 110)
        print("          CONSOLIDAÇÃO NA ESCALA DE TURNOS (relógio interno em minutos)")
        print("=" * 110)
        print(f"Jornada semanal CLT......: {DadosConfig.JORNADA_SEMANAL_CLT:,.0f} min  (44,0 h)")
        print(f"Jornada semanal Estágio..: {DadosConfig.JORNADA_SEMANAL_ESTAGIO:,.0f} min  (27,5 h | 5,5h x 5 dias, sem sábado)")
        print(f"Semana simulada..........: {DadosConfig.LIMITES_DIAS[-1]:,.0f} min  (44,0 h | 5 dias x 8h + 1 sábado x 4h)")
        print("-" * 110)
        for cenario_id, linha in self.df.iterrows():
            lt_horas = linha['Lead Time Médio (min)'] / 60.0
            fila_horas = linha['Tempo em Fila (min)'] / 60.0
            print(f"{linha['Nome Cenário']:<62s} Lead Time: {lt_horas:5.2f} h | Fila: {fila_horas:5.2f} h")
        print("=" * 110)

    def comparar_estrategias_balanceamento(self) -> None:
        
        ids_interesse = [1, 4, 5, 7, 8]
        ids_interesse = [i for i in ids_interesse if i in self.df.index]

        print("\n" + "#" * 110)
        print(" COMPARAÇÃO DIRETA: BALANCEAMENTO ENXUTO (sem custo) x EXPANSÃO DE CAPACIDADE (com custo)")
        print("#" * 110)
        colunas_foco = ['Nome Cenário', 'Produção Semanal', 'Lead Time Médio (min)',
                        'Tempo em Fila (min)', 'Utilização Média', 'Score Eficiência']
        print(self.df.loc[ids_interesse, colunas_foco].to_string(index=False, formatters={
            'Produção Semanal': '{:,.1f}'.format,
            'Lead Time Médio (min)': '{:,.2f}'.format,
            'Tempo em Fila (min)': '{:,.2f}'.format,
            'Utilização Média': '{:.2%}'.format,
            'Score Eficiência': '{:,.3f}'.format,
        }))
        print("#" * 110)

    def gerar_ranking_e_conclusao(self) -> None:
        df_ranking = self.df.sort_values(by='Score Eficiência', ascending=False)
        melhor_cenario_id = df_ranking.index[0]
        melhor_cenario = df_ranking.iloc[0]

        atual = self.df.loc[1]

        ganho_producao = ((melhor_cenario['Produção Semanal'] - atual['Produção Semanal']) / atual['Produção Semanal']) * 100
        reducao_lt = ((atual['Lead Time Médio (min)'] - melhor_cenario['Lead Time Médio (min)']) / atual['Lead Time Médio (min)']) * 100
        reducao_wip = ((atual['WIP Médio (pedidos)'] - melhor_cenario['WIP Médio (pedidos)']) / atual['WIP Médio (pedidos)']) * 100
        melhoria_score = ((melhor_cenario['Score Eficiência'] - atual['Score Eficiência']) / atual['Score Eficiência']) * 100

        print("\n" + "#" * 110)
        print(f" RANKING INTEGRADO (MÚLTIPLOS CRITÉRIOS): O melhor cenário para o fluxo global foi o {melhor_cenario['Nome Cenário']}.")
        print("#" * 110)
        print("\nCONCLUSÃO AUTOMÁTICA DO TCC:")
        print("Ao analisar o sistema produtivo sob a ótica da Engenharia de Produção, priorizar a produção bruta")
        print("empurrada sem controle de filas mascara a ineficiência logística (explosão de lead time e WIP).")
        print("Utilizando um Score de Eficiência que balanceia Vazão e Tempo de Atravessamento, o simulador SimPy")
        print(f"determinou que o cenário ótimo para a Empresa Alpha é o '{melhor_cenario['Nome Cenário']}'.")
        print("\nA adoção deste modelo operacional em detrimento da Situação Atual acarreta os seguintes ganhos:")
        print(f" 1. Evolução no Score de Eficiência do Fluxo: +{melhoria_score:.2f}% de harmonia entre tempo e volume.")
        print(f" 2. Impacto em Volume: Variação de {ganho_producao:+.2f}% na Produção Semanal de pedidos expedidos.")
        print(f" 3. Impacto no Tempo de Atravessamento: Redução de {reducao_lt:.2f}% no Lead Time Médio dos lotes.")
        print(f" 4. Otimização do Estoque em Processo: Redução de {reducao_wip:.2f}% no WIP médio em linha.")
        print(f" 5. Análise da Restrição: O gargalo predominante estabilizou-se no posto '{melhor_cenario['Gargalo Identificado']}'.")

        ic_producao = melhor_cenario.get('Produção Semanal (IC95%)')
        ic_lt = melhor_cenario.get('Lead Time Médio (min) (IC95%)')
        if ic_producao is not None and ic_lt is not None:
            print(f" 6. Confiabilidade Estatística (IC 95%): a Produção Semanal do cenário ótimo foi de "
                  f"{melhor_cenario['Produção Semanal']:.1f} ± {ic_producao:.1f} pedidos, e o Lead Time Médio foi de "
                  f"{melhor_cenario['Lead Time Médio (min)']:.2f} ± {ic_lt:.2f} min, com 95% de confiança.")

        # Nota específica separando as duas naturezas de intervenção
        if 7 in self.df.index and 8 in self.df.index:
            lean_sem_custo = self.df.loc[7]
            lean_com_custo = self.df.loc[8]
            print(" 7. Balanceamento (sem custo) x Expansão (com custo): o cenário 'Lean Completo' entregou "
                  f"{lean_sem_custo['Produção Semanal']:.1f} pedidos/semana sem contratação, contra "
                  f"{lean_com_custo['Produção Semanal']:.1f} pedidos/semana no cenário com a contratação do "
                  "11º operador - use essa diferença para justificar (ou não) o investimento no TCC.")
        print("-" * 110)

    def plotar_graficos(self) -> None:
        labels = [f"C{i}" for i in self.df.index]

        plt.figure(figsize=(15, 5))

        plt.subplot(1, 3, 1)
        colors = ['#1f77b4' if x != self.df['Score Eficiência'].max() else '#2ca02c' for x in self.df['Score Eficiência']]
        bars1 = plt.bar(labels, self.df['Score Eficiência'], color=colors)
        plt.title('Score de Eficiência Global (Lean)')
        plt.xlabel('Cenários')
        plt.ylabel('Produção / Lead Time')
        for bar in bars1:
            yval = bar.get_height()
            plt.text(bar.get_x() + bar.get_width() / 2.0, yval + (yval * 0.01), f"{yval:.2f}", ha='center', va='bottom', fontsize=9)

        plt.subplot(1, 3, 2)
        erro_lt = self.df['Lead Time Médio (min) (IC95%)'] if 'Lead Time Médio (min) (IC95%)' in self.df.columns else None
        bars2 = plt.bar(labels, self.df['Lead Time Médio (min)'], yerr=erro_lt, capsize=4, color='#d62728')
        plt.title('Lead Time Médio (min) — barras: IC 95%')
        plt.xlabel('Cenários')
        plt.ylabel('Minutos')
        for bar in bars2:
            yval = bar.get_height()
            plt.text(bar.get_x() + bar.get_width() / 2.0, yval + (yval * 0.01), f"{yval:.1f}", ha='center', va='bottom', fontsize=9)

        plt.subplot(1, 3, 3)
        erro_wip = self.df['WIP Médio (pedidos) (IC95%)'] if 'WIP Médio (pedidos) (IC95%)' in self.df.columns else None
        bars3 = plt.bar(labels, self.df['WIP Médio (pedidos)'], yerr=erro_wip, capsize=4, color='#ff7f0e')
        plt.title('WIP Médio (Pedidos) — barras: IC 95%')
        plt.xlabel('Cenários')
        plt.ylabel('Quantidade de Pedidos')
        for bar in bars3:
            yval = bar.get_height()
            plt.text(bar.get_x() + bar.get_width() / 2.0, yval + (yval * 0.01), f"{yval:.1f}", ha='center', va='bottom', fontsize=9)

        plt.tight_layout()
        plt.savefig("resultado_cenarios.png", dpi=150)
        print("\n[INFO] Gráficos salvos em 'resultado_cenarios.png'.")
        plt.show()

if __name__ == "__main__":

